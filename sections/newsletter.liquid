<div class="newsletter">
  <div class="newsletter__inner">
    <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
    <p class="newsletter__subheading">{{ section.settings.subheading }}</p>
    {% form 'customer', class: 'newsletter__form' %}
      {%- if form.posted_successfully? -%}
        <p class="newsletter__success">You're in. Welcome to the crew.</p>
      {%- else -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__field">
          <input type="email" name="contact[email]" placeholder="Email address" required aria-label="Email address">
          <button type="submit">Join</button>
        </div>
      {%- endif -%}
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "JOIN THE CREW" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Drops, races, and restocks — straight to your inbox." }
  ]
}
{% endschema %}
