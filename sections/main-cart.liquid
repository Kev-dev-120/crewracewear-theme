<section class="cart-page">
  <h1>Your Cart</h1>
  {%- if cart.item_count == 0 -%}
    <p class="cart-page__empty">Your cart is empty.</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Continue shopping</a>
  {%- else -%}
    {% form 'cart', cart, class: 'cart-page__form' %}
      <table class="cart-page__table">
        <thead>
          <tr><th>Product</th><th>Price</th><th>Qty</th><th>Total</th></tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr>
              <td class="cart-page__product">
                {%- if item.image -%}<img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" width="120" loading="lazy">{%- endif -%}
                <div>
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}<p class="cart-page__variant">{{ item.variant.title }}</p>{%- endunless -%}
                </div>
              </td>
              <td>{{ item.original_price | money }}</td>
              <td><input type="number" name="updates[{{ forloop.index0 }}]" value="{{ item.quantity }}" min="0"></td>
              <td>{{ item.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
      <div class="cart-page__footer">
        <p class="cart-page__subtotal">Subtotal: {{ cart.total_price | money }}</p>
        <button type="submit" name="update" class="btn btn--ghost">Update cart</button>
        <button type="submit" name="checkout" class="btn btn--primary">Checkout</button>
      </div>
    {% endform %}
  {%- endif -%}
</section>

{% schema %}
{ "name": "Cart page", "settings": [] }
{% endschema %}
