<footer class="site-footer">
  <div class="site-footer__inner">

    <div class="site-footer__brand">
      <span class="site-footer__logo">{{ shop.name | default: 'CREW RACEWEAR' }}</span>
      <p>{{ section.settings.tagline }}</p>
      <div class="site-footer__socials">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" aria-label="Instagram">IG</a>
        {%- endif -%}
        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}" aria-label="YouTube">YT</a>
        {%- endif -%}
        {%- if section.settings.discord_url != blank -%}
          <a href="{{ section.settings.discord_url }}" aria-label="Discord">DC</a>
        {%- endif -%}
      </div>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="site-footer__col" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading }}</h3>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  <div class="site-footer__bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <p>{{ section.settings.contact_email }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Built by racers, for racers." },
    { "type": "text", "id": "contact_email", "label": "Contact email", "default": "crewracewear@gmail.com" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "url", "id": "discord_url", "label": "Discord URL" }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
