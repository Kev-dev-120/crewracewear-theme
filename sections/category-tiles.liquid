<section class="category-tiles">
  {%- if section.settings.heading != blank -%}
    <div class="section-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}
  <div class="category-tiles__grid" style="--cols:{{ section.blocks.size }};">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url }}" class="category-tile" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="800" height="{{ 800 | divided_by: block.settings.image.aspect_ratio }}">
        {%- endif -%}
        <span class="category-tile__label">{{ block.settings.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category tiles",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP BY COLLECTION" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "STRIKE" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Category tiles",
      "blocks": [
        { "type": "tile", "settings": { "title": "STRIKE" } },
        { "type": "tile", "settings": { "title": "SURGE" } },
        { "type": "tile", "settings": { "title": "RGB COLLECTION" } },
        { "type": "tile", "settings": { "title": "TEES" } }
      ]
    }
  ]
}
{% endschema %}
