<header class="site-header" data-header>
  <div class="site-header__inner">

    <button class="site-header__menu-toggle" data-menu-toggle aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" loading="eager">
      {%- else -%}
        <span class="site-header__logo-text">{{ shop.name | default: 'CREW RACEWEAR' }}</span>
      {%- endif -%}
    </a>

    <nav class="site-nav" aria-label="Main menu">
      <ul class="site-nav__list">
        {%- for link in section.settings.main_menu.links -%}
          <li class="site-nav__item{% if link.links != blank %} has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="site-nav__link">{{ link.title }}</a>
            {%- if link.links != blank -%}
              <div class="site-nav__dropdown">
                <ul>
                  {%- for childlink in link.links -%}
                    <li><a href="{{ childlink.url }}">{{ childlink.title }}</a></li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="site-header__icons">
      <button class="site-header__icon" data-search-toggle aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="site-header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>

  <div class="search-drawer" data-search-drawer>
    <form action="{{ routes.search_url }}" method="get" class="search-drawer__form">
      <input type="search" name="q" placeholder="Search products…" aria-label="Search">
      <button type="submit">Search</button>
    </form>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 160,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
